---
const features = [
  {
    title: 'Understanding your needs',
    description: 'A complimentary consultation to understand your goals. We brainstorm and work with you to find the best path.',
    step: '01',
  },
  {
    title: 'Scope & quotation',
    description: 'A detailed scope of work and quotation for your approval. We refine the scope and phase the project together.',
    step: '02',
  },
  {
    title: 'Project plan',
    description: 'A clear plan and schedule. You get updates on progress and milestones the entire way through.',
    step: '03',
  },
  {
    title: 'Creative design',
    description: 'Our team creates a design unique to your business and brand — then refines it until you are 100% happy.',
    step: '04',
  },
  {
    title: 'Development',
    description: 'We build with the latest technologies and best practices, with regular check-ins and demos.',
    step: '05',
  },
  {
    title: 'Test, deploy & support',
    description: 'We test, deploy, and continue to provide maintenance and support to keep things running smoothly.',
    step: '06',
  },
]
---

<section class="mt-24 lg:mt-32">
  <div class="max-w-3xl mx-auto text-center" data-reveal>
    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Our process</p>
    <h2 class="mt-3 text-4xl lg:text-6xl font-semibold tracking-[-0.03em] text-slate-900 [text-wrap:balance]">
      We've got you <span class="text-gradient-dark">covered</span>.
    </h2>
    <p class="mt-5 text-lg text-slate-600 [text-wrap:pretty]">
      As your digital partner, we keep everything running smoothly and continue to support you as your needs grow.
    </p>
  </div>

  <div class="mt-16 relative" data-reveal-stagger data-stagger-base="80">
    <div class="hidden lg:block absolute left-0 right-0 top-[28px] h-px bg-slate-200" aria-hidden="true"></div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-12">
      {features.map((item) => (
        <div class="step-card relative group">
          <span class="relative grid place-items-center w-14 h-14 rounded-full bg-white ring-1 ring-slate-200 text-slate-900 transition-shadow group-hover:shadow-md">
            <span class="font-semibold tabular-nums text-base">{item.step}</span>
          </span>
          <h3 class="mt-5 text-xl font-semibold tracking-tight text-slate-900">{item.title}</h3>
          <p class="mt-2 text-slate-600 leading-relaxed [text-wrap:pretty]">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
