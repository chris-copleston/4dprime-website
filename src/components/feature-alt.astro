---
import { Picture } from 'astro:assets'
import FeatureImg2 from '../assets/features/2.png'
import Link from '@components/ui/link.astro'
import YouTube from '@components/youtube.astro'
import homeYoutubeCover from '../assets/home-youtube-cover.jpg'

const { nomargin } = Astro.props
---

<section class:list={['relative', !nomargin && 'mt-24 lg:mt-32']}>
  <div class="max-w-3xl mx-auto text-center" data-reveal>
    <p class="text-xs uppercase tracking-[0.18em] text-slate-500">
      Why choose us
    </p>
    <h2
      class="mt-3 text-4xl lg:text-6xl font-semibold tracking-[-0.03em] text-slate-900 [text-wrap:balance]">
      We empower businesses <span class="text-gradient-dark">like yours</span>
      to thrive.
    </h2>
    <p class="mt-5 text-lg text-slate-600 [text-wrap:pretty]">
      Cutting-edge mobile apps, websites, custom AI and bespoke software &mdash;
      tailored to your unique business needs.
    </p>
  </div>

  <div class="grid md:grid-cols-2 gap-10 lg:gap-16 py-16 items-center">
    <div class="grid place-items-center" data-reveal>
      <div class="relative w-full">
        <div
          class="relative rounded-2xl overflow-hidden ring-1 ring-slate-200 shadow-sm">
          <YouTube
            class="rounded-2xl"
            embedParams={{ rel: 0, controls: 1, autoplay: 1 }}
            thumbnailRes="maxres"
            thumbnailSrc={homeYoutubeCover.src}
            title="4DPrime - The Future of Digital Marketing"
            videoId="E92AL5sb_u8"
          />
        </div>
      </div>
    </div>

    <div data-reveal data-reveal-delay="120">
      <h3
        class="text-3xl font-semibold tracking-tight text-slate-900 [text-wrap:balance]">
        Boost your business.
      </h3>
      <p class="mt-4 text-slate-600 [text-wrap:pretty]">
        Our team of talented developers, designers and engineers are masters of
        their craft, with decades of experience creating exceptional digital
        solutions.
      </p>

      <ul class="grid mt-7 gap-y-4">
        <li class="flex items-start gap-3 text-slate-800">
          <svg
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-5 h-5 mt-0.5 text-iris shrink-0">
            <path d="m5 10 4 4 7-8"></path>
          </svg>
          <span>100% in-house experts</span>
        </li>
        <li class="flex items-start gap-3 text-slate-800">
          <svg
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-5 h-5 mt-0.5 text-iris shrink-0">
            <path d="m5 10 4 4 7-8"></path>
          </svg>
          <span>Over 25 years in business</span>
        </li>
        <li class="flex items-start gap-3 text-slate-800">
          <svg
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-5 h-5 mt-0.5 text-iris shrink-0">
            <path d="m5 10 4 4 7-8"></path>
          </svg>
          <span>Friendly support and advice</span>
        </li>
      </ul>

      <div class="mt-8">
        <a href="/contact/" class="btn-ghost">
          Chat with an expert
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="w-4 h-4">
            <path
              fill-rule="evenodd"
              d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-10 lg:gap-16 py-16 items-center">
    <div class="grid place-items-center order-2" data-reveal>
      <div class="relative w-full">
        <Picture
          src={FeatureImg2}
          alt="Feature Image"
          formats={['avif', 'webp']}
          fallbackFormat="jpg"
          width={600}
          densities={[1, 2]}
          loading="lazy"
          class="relative rounded-2xl w-full h-auto ring-1 ring-slate-200"
        />
      </div>
    </div>

    <div data-reveal data-reveal-delay="120">
      <h3
        class="text-3xl font-semibold tracking-tight text-slate-900 [text-wrap:balance]">
        The 4DPrime difference.
      </h3>
      <p class="mt-4 text-slate-600 [text-wrap:pretty]">
        We stay sharp on the latest design, technologies and frameworks so your
        business has the edge.
      </p>
      <ul class="grid mt-7 gap-y-4">
        <li class="flex items-start gap-3 text-slate-800">
          <svg
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-5 h-5 mt-0.5 text-iris shrink-0"
            ><path d="m5 10 4 4 7-8"></path></svg
          >
          <span>One codebase for Android &amp; iOS &mdash; lower cost</span>
        </li>
        <li class="flex items-start gap-3 text-slate-800">
          <svg
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-5 h-5 mt-0.5 text-iris shrink-0"
            ><path d="m5 10 4 4 7-8"></path></svg
          >
          <span>Websites that are blazingly fast &amp; accessible</span>
        </li>
        <li class="flex items-start gap-3 text-slate-800">
          <svg
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-5 h-5 mt-0.5 text-iris shrink-0"
            ><path d="m5 10 4 4 7-8"></path></svg
          >
          <span>AI tailored to your systems, products &amp; services</span>
        </li>
        <li class="flex items-start gap-3 text-slate-800">
          <svg
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-5 h-5 mt-0.5 text-iris shrink-0"
            ><path d="m5 10 4 4 7-8"></path></svg
          >
          <span>Bespoke software that's secure &amp; scalable</span>
        </li>
      </ul>
      <div class="mt-8">
        <a href="/contact/" class="btn-ghost">
          Let's discuss your project
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="w-4 h-4">
            <path
              fill-rule="evenodd"
              d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
