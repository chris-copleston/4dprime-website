---
const { layout = 'marquee' } = Astro.props // 'grid', 'marquee'

import Container from '@components/container.astro'
import Review from '@components/review.astro'
import GarethHector from '../assets/people/gareth-hector-headshot.jpg'
import ScottKnox from '../assets/people/scott-knox-headshot.jpg'
import GlenMejias from '../assets/people/glen-mejias-headshot.jpg'
import PhilMason from '../assets/people/phil-mason-headshot.jpg'
import SimonMehlman from '../assets/people/simon-mehlman-headshot.jpg'
import JamieSimmonds from '../assets/people/jamie-simmonds-headshot.jpg'
import PhillipCampbell from '../assets/people/phillip-campbell-headshot.jpg'
import AdamThomas from '../assets/people/adam-thomas-headshot.jpg'
import NancyJardine from '../assets/people/nancy-jardine-headshot.jpg'

const testimonials = [
  {
    name: 'Gareth Hector',
    title: 'Partner at MaxHector Photography',
    image: GarethHector,
    text: '4DPrime brought us a fresh view not just on how web sites can be built and maintained but also a view on our business and what we were trying to achieve.<br><br>We think we have a site that we have not seen ever before. Unique sells.',
  },
  {
    name: 'Scott Knox',
    title: 'President & CEO at Institute of Canadian Agencies (ICA)',
    image: ScottKnox,
    text: 'I have worked with 4DPrime for over 15 years and both sides of the Atlantic. Their bespoke and business-like approach means getting to results and delivery quickly. They respond and create with a sense of purpose and urgency.<br><br>The 4DPrime team certainly set the pace for ideas and client service standards.',
  },
  {
    name: 'Glen Mejias',
    title: 'Director at Chilford Hall',
    image: GlenMejias,
    text: 'We needed a complete website overhaul and 4DPrime executed the brief well, providing us with a well-designed and more contemporary site.<br><br>Highly knowledgeable and professional at all times, I would not hesitate in recommending 4DPrime to others!',
  },
  {
    name: 'Phil Mason',
    title: 'Creative Director at Hype Studios',
    image: PhilMason,
    text: 'We approached 4DPrime to assist us with the development of an iPad app project.<br><br>From the outset Chris and his team were extremely easy to deal with and delivered a great solution within a very tight budget.',
  },
  {
    name: 'Simon Mehlman',
    title: 'Group Marketing Manager at Ascribe',
    image: SimonMehlman,
    text: '4DPrime is one of those rare companies that manages to treat customers with both professionalism and a personalised, caring service.<br><br>I have been consistently impressed by their creativity, their helpfulness and the guidance of their technical support teams throughout the construction and launch of our new corporate web presence.',
  },
  {
    name: 'Adam Thomas',
    title: 'Director at Gascony Experience',
    image: AdamThomas,
    text: "Through 4DPrime's expertise and clarity of thinking we now have a powerful and flexible on line tourism platform.<br><br>It was a pleasure working with a great team who were always available to help and advise.",
  },
  {
    name: 'Jamie Simmonds',
    title: 'CEO at TheTin',
    image: JamieSimmonds,
    text: 'Working with the guys at 4DPrime has been really productive and beneficial to our business.<br><br>They were brought in at short notice, on an extremely technical and specialist project and hit all the deadlines and worked tirelessly to ensure the deliverables were met. I would not hesitate in using them again.',
  },
  {
    name: 'Nancy Jardine',
    title:
      'Administrator at National Aerospace Technology Exploitation Programme (NATEP)',
    image: NancyJardine,
    text: 'As a (relatively new user) I cannot recommend  4DPrime highly enough for their patience when training and for their extremely prompt action to resolve any issues raised with them.',
  },
  {
    name: 'Phillip Campbell',
    title: 'Senior Analyst at Alpha Business Analysis ',
    image: PhillipCampbell,
    text: 'Rough estimates suggest that I have saved about £6,000 with 4DPrime against using another company to produce the same results.',
  },
]
---

{ layout == 'grid' ? (
  <Container>
  <div class="grid grid-cols-1 md:grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-10 mt-10" style="justify-items: center;">
    {testimonials.map((item) => <Review {...item} />)}
  </div>
  </Container>
) : null}

{ layout == 'marquee' ? (
  <div class="mt-10 testimonials-carousel" data-pagefind-ignore>
    <div class="carousel-stage" data-carousel-stage>
      {testimonials.map((item, i) => (
        <div class="carousel-card" data-carousel-card data-index={i}>
          <Review {...item} />
        </div>
      ))}
    </div>

    <div class="carousel-controls">
      <button class="carousel-arrow" data-carousel-prev aria-label="Previous testimonial">
        <svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 010 1.06L8.832 10l3.958 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.04.02z" clip-rule="evenodd"/></svg>
      </button>
      <div class="carousel-dots" data-carousel-dots>
        {testimonials.map((_, i) => (
          <button class="carousel-dot" data-carousel-jump={i} aria-label={`Go to testimonial ${i + 1}`}></button>
        ))}
      </div>
      <button class="carousel-arrow" data-carousel-next aria-label="Next testimonial">
        <svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/></svg>
      </button>
    </div>
  </div>
) : null}

<style>
  .testimonials-carousel {
    width: 100%;
    overflow: hidden;
  }

  .carousel-stage {
    position: relative;
    width: 100%;
    height: clamp(360px, 46vh, 460px);
    perspective: 1400px;
    perspective-origin: 50% 55%;
    transform-style: preserve-3d;
  }

  .carousel-card {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(280px, 78vw, 520px);
    transform-style: preserve-3d;
    transform-origin: 50% 50%;
    transition:
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity, filter;
    cursor: pointer;
  }

  .carousel-card :global(.review) {
    margin: 0;
    width: 100%;
    height: 100%;
    transition:
      box-shadow 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Foremost (centred) card: dramatic drop shadow + subtle indigo edge so
     it visually pops forward from the rest of the carousel. */
  .carousel-card[data-active='true'] :global(.review) {
    box-shadow:
      0 36px 70px -22px rgba(15, 23, 42, 0.45),
      0 16px 32px -10px rgba(15, 23, 42, 0.25),
      0 0 0 1px rgba(99, 102, 241, 0.18);
    transform: scale(1.04);
  }

  .carousel-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .carousel-arrow {
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    border: 1px solid rgb(226, 232, 240);
    background: white;
    color: rgb(71, 85, 105);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .carousel-arrow:hover {
    background: rgb(248, 250, 252);
    color: rgb(15, 23, 42);
    border-color: rgb(203, 213, 225);
  }

  .carousel-dots {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0 0.5rem;
  }
  .carousel-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgb(203, 213, 225);
    border: 0;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
    cursor: pointer;
  }
  .carousel-dot[data-active='true'] {
    background: rgb(99, 102, 241);
    transform: scale(1.4);
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-card { transition: none; }
  }
</style>

<script>
  function initTestimonialCarousel() {
    const stage = document.querySelector<HTMLElement>('[data-carousel-stage]')
    if (!stage) return
    const cards = Array.from(
      stage.querySelectorAll<HTMLElement>('[data-carousel-card]'),
    )
    const total = cards.length
    if (!total) return

    const dotsHost = document.querySelector('[data-carousel-dots]')
    const dots = dotsHost
      ? Array.from(dotsHost.querySelectorAll<HTMLElement>('[data-carousel-jump]'))
      : []
    const prevBtn = document.querySelector<HTMLElement>('[data-carousel-prev]')
    const nextBtn = document.querySelector<HTMLElement>('[data-carousel-next]')

    let idx = 0
    let interval: ReturnType<typeof setInterval> | null = null
    let paused = false

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    function getStep() {
      const w = stage!.clientWidth
      if (w < 640) return Math.min(180, w * 0.34)
      if (w < 1024) return 220
      return 260
    }

    function update() {
      const step = getStep()
      for (let i = 0; i < total; i++) {
        let offset = i - idx
        if (offset > total / 2) offset -= total
        if (offset < -total / 2) offset += total

        const abs = Math.abs(offset)
        const visible = abs <= 2
        const tx = offset * step
        const tz = -abs * 180
        const ry = offset * -22

        const card = cards[i]
        card.style.transform = `translate(-50%, -50%) translateX(${tx}px) translateZ(${tz}px) rotateY(${ry}deg)`
        // All visible cards stay fully opaque so text is readable —
        // depth comes from translateZ + rotateY perspective, not alpha.
        card.style.opacity = visible ? '1' : '0'
        // Slight depth-of-field blur on background cards.
        card.style.filter = abs === 0 ? 'none' : `blur(${abs * 1.4}px)`
        card.style.zIndex = String(total - abs)
        card.style.pointerEvents = abs === 0 ? 'auto' : 'none'
        card.setAttribute('aria-hidden', abs === 0 ? 'false' : 'true')
        card.setAttribute('data-active', abs === 0 ? 'true' : 'false')
      }
      dots.forEach((d, i) => {
        d.setAttribute('data-active', i === idx ? 'true' : 'false')
      })
    }

    function go(delta: number) {
      idx = (idx + delta + total) % total
      update()
    }

    function start() {
      if (reduced) return
      if (interval) clearInterval(interval)
      interval = setInterval(() => {
        if (!paused) go(1)
      }, 6000)
    }

    prevBtn?.addEventListener('click', () => {
      go(-1)
      start()
    })
    nextBtn?.addEventListener('click', () => {
      go(1)
      start()
    })
    dots.forEach((d, i) => {
      d.addEventListener('click', () => {
        idx = i
        update()
        start()
      })
    })

    cards.forEach((card, i) => {
      card.addEventListener('click', () => {
        if (i === idx) return
        idx = i
        update()
        start()
      })
    })

    stage.addEventListener('pointerenter', () => {
      paused = true
    })
    stage.addEventListener('pointerleave', () => {
      paused = false
    })

    const ro = new ResizeObserver(update)
    ro.observe(stage)

    update()
    start()
  }

  initTestimonialCarousel()
  document.addEventListener('astro:after-swap', initTestimonialCarousel)
</script>
