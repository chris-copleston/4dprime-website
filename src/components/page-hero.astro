---
import ShaderCanvas from '@components/shader-canvas.astro'

interface Props {
  variant?: 'aurora' | 'plasma' | 'grid' | 'mesh' | 'liquid' | 'spectrum' | 'noir'
  badge?: string
  accent?: 'iris' | 'violet' | 'cyan' | 'plasma' | 'solar'
  intensity?: number
}

const { variant = 'noir', badge, intensity = 1 } = Astro.props
---

<section class="page-hero relative overflow-hidden bg-ink text-bone -mt-20">
  <ShaderCanvas variant={variant} intensity={intensity} />
  <div class="absolute inset-x-0 top-0 h-px bg-white/[0.06]"></div>

  <div class="relative z-10 max-w-screen-xl mx-auto px-5 pt-20 pb-28 lg:pt-28 lg:pb-36">
    <div class="max-w-3xl">
      {badge && (
        <div data-reveal class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 backdrop-blur-sm px-3 py-1.5 text-xs tracking-[0.18em] uppercase text-bone/75">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-white/80"></span>
          {badge}
        </div>
      )}

      <h1
        data-reveal
        data-reveal-delay="80"
        class="mt-7 text-5xl sm:text-6xl lg:text-7xl font-semibold tracking-[-0.035em] leading-[1.02] [text-wrap:balance]">
        <slot name="title" />
      </h1>

      <div data-reveal data-reveal-delay="200" class="mt-6 text-lg lg:text-xl text-bone/65 max-w-2xl [text-wrap:balance] leading-relaxed">
        <slot name="desc" />
      </div>

      <slot name="actions" />
    </div>
  </div>

  <!-- Curved horizon: huge white disc whose top arc spans the full width.
       Soft glow above bleeds into the dark sky for an atmospheric edge. -->
  <div class="page-hero-horizon" aria-hidden="true">
    <div class="page-hero-glow"></div>
    <div class="page-hero-edge"></div>
    <div class="page-hero-planet"></div>
  </div>
</section>

<style>
  .page-hero-horizon {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 160px;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  /* Soft white halo above the horizon, screen-blended for a glow. */
  .page-hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 170% 70% at 50% 115%,
      rgba(255, 255, 255, 0.78) 0%,
      rgba(245, 250, 255, 0.5) 16%,
      rgba(220, 232, 255, 0.25) 42%,
      rgba(200, 218, 255, 0.08) 68%,
      transparent 88%
    );
    mix-blend-mode: screen;
    opacity: 0.85;
  }
  /* Gradient-coloured edge sitting just above the white planet. Only the
     top sliver shows as a thin curved rim of colour along the horizon. */
  .page-hero-edge {
    --planet-d: 800vw;
    position: absolute;
    left: 50%;
    top: calc(100% - 53px);
    width: var(--planet-d);
    height: var(--planet-d);
    margin-left: calc(var(--planet-d) / -2);
    border-radius: 50%;
    background: linear-gradient(
      110deg,
      #6366F1 0%,
      #8B5CF6 25%,
      #C084FC 50%,
      #F472B6 75%,
      #60A5FA 100%
    );
    filter: blur(0.5px);
  }
  /* Huge white disc — its top arc is visible across the full page width
     creating the curved horizon. Sits 3px below the coloured edge so the
     gradient rim is visible. */
  .page-hero-planet {
    --planet-d: 800vw;
    position: absolute;
    left: 50%;
    top: calc(100% - 50px);
    width: var(--planet-d);
    height: var(--planet-d);
    margin-left: calc(var(--planet-d) / -2);
    border-radius: 50%;
    background: #ffffff;
  }
  @media (max-width: 640px) {
    .page-hero-horizon { height: 120px; }
    .page-hero-edge {
      --planet-d: 1100vw;
      top: calc(100% - 39px);
    }
    .page-hero-planet {
      --planet-d: 1100vw;
      top: calc(100% - 36px);
    }
  }
</style>
