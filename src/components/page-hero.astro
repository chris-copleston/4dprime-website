---
import ShaderCanvas from '@components/shader-canvas.astro'

interface Props {
  variant?: 'aurora' | 'plasma' | 'grid' | 'mesh' | 'liquid' | 'spectrum' | 'noir'
  badge?: string
  accent?: 'iris' | 'violet' | 'cyan' | 'plasma' | 'solar'
}

const { variant = 'noir', badge } = Astro.props
---

<section class="page-hero relative overflow-hidden bg-ink text-bone -mt-20">
  <ShaderCanvas variant={variant} intensity={1} />
  <div class="absolute inset-x-0 top-0 h-px bg-white/[0.06]"></div>

  <div class="relative z-10 max-w-screen-xl mx-auto px-5 pt-20 pb-28 lg:pt-28 lg:pb-36">
    <div class="max-w-3xl">
      {badge && (
        <div data-reveal class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 backdrop-blur-sm px-3 py-1.5 text-xs tracking-[0.18em] uppercase text-bone/75">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-white/80"></span>
          {badge}
        </div>
      )}

      <h1
        data-reveal
        data-reveal-delay="80"
        class="mt-7 text-5xl sm:text-6xl lg:text-7xl font-semibold tracking-[-0.035em] leading-[1.02] [text-wrap:balance]">
        <slot name="title" />
      </h1>

      <div data-reveal data-reveal-delay="200" class="mt-6 text-lg lg:text-xl text-bone/65 max-w-2xl [text-wrap:balance] leading-relaxed">
        <slot name="desc" />
      </div>

      <slot name="actions" />
    </div>
  </div>

  <!-- bottom gradient fade to white -->
  <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-b from-transparent to-white pointer-events-none z-[2]"></div>
</section>
