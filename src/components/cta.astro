---

---

<section class="relative overflow-hidden mt-24 cta-section text-bone">
  <!-- Horizon divider: warm gold rim where the white copy meets the dark CTA/footer -->
  <div class="cta-horizon" aria-hidden="true"></div>

  <div
    class="relative z-10 px-6 md:px-20 py-24 md:py-32 flex flex-col items-center text-center">
    <div
      data-reveal
      class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 backdrop-blur px-3 py-1.5 text-xs uppercase tracking-[0.18em] text-bone/75">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-white/80"></span>
       Ready when you are
    </div>

    <h2
      data-reveal
      data-reveal-delay="80"
      class="mt-7 text-5xl md:text-7xl lg:text-[5.5rem] font-semibold tracking-[-0.035em] leading-[1.02] [text-wrap:balance] max-w-4xl">
      Launch your <span class="text-gradient">next idea</span>.
    </h2>

    <p
      data-reveal
      data-reveal-delay="200"
      class="text-bone/65 mt-6 text-lg md:text-xl max-w-xl [text-wrap:balance] leading-relaxed">
      Get the 4DPrime advantage. Talk to a friendly expert about launching your
      next project &mdash; no obligation, no auto-responders.
    </p>

    <div
      data-reveal
      data-reveal-delay="320"
      class="mt-10 flex flex-col sm:flex-row gap-3 items-center">
      <a href="/contact" class="btn-primary btn-magnetic group">
        <span>Request your free consultation</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          class="w-4 h-4 transition-transform group-hover:translate-x-1">
          <path
            fill-rule="evenodd"
            d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
            clip-rule="evenodd"></path>
        </svg>
      </a>
      <a href="tel:+441376350001" class="btn-ghost-dark">
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor"
          ><path
            d="M19.44 13c-.22 0-.45-.07-.67-.12a9.44 9.44 0 0 1-1.31-.39 2 2 0 0 0-2.48 1l-.22.45a12.18 12.18 0 0 1-2.66-2 12.18 12.18 0 0 1-2-2.66l.42-.28a2 2 0 0 0 1-2.48 10.33 10.33 0 0 1-.39-1.31c-.05-.22-.09-.45-.12-.68a3 3 0 0 0-3-2.49h-3a3 3 0 0 0-3 3.41 19 19 0 0 0 16.52 16.46h.38a3 3 0 0 0 2-.76 3 3 0 0 0 1-2.25v-3a3 3 0 0 0-2.47-2.9z"
          ></path></svg
        >
         +44 (0) 1376 350001
      </a>
    </div>
  </div>
</section>

<style>
  /* Pure neutral dark — no indigo undertones so the gradient above resolves
     into a clean black instead of revealing a blue band. */
  .cta-section {
    background: #06060f;
  }

  /* White copy above → warm horizon line → dark CTA body below.
     Mirrors the hero's sunrise transition, flipped. */
  .cta-horizon {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 150px;
    z-index: 3;
    pointer-events: none;
    /* Stays in warm/neutral tones — no indigo in the gradient, so there's
       no bluish band between the rim line and the deep dark. */
    background: linear-gradient(
      180deg,
      #ffffff 0%,
      #ffffff 38%,
      rgba(255, 205, 140, 0.65) 46%,
      rgba(80, 38, 18, 0.85) 51%,
      rgba(20, 10, 6, 0.96) 60%,
      #04040a 78%,
      #06060f 100%
    );
  }
  .cta-horizon::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    transform: translateY(-50%);
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 180, 110, 0.55) 20%,
      rgba(255, 210, 145, 0.95) 50%,
      rgba(255, 180, 110, 0.55) 80%,
      transparent 100%
    );
    filter: blur(0.4px);
    box-shadow: 0 0 22px rgba(255, 185, 115, 0.55);
  }
</style>
