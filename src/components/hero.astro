---
import ShaderCanvas from '@components/shader-canvas.astro'
---

<section
  class="hero relative overflow-hidden bg-ink text-bone"
  data-pagefind-ignore="all"
  transition:persist>
  <!-- Cinematic shader at reduced intensity, just for atmospheric depth -->
  <ShaderCanvas variant="cinematic" intensity={0.55} />

  <div class="absolute inset-x-0 top-0 h-px bg-white/[0.06]"></div>

  <!-- Particle text canvas — fills the hero, sits above the shader. -->
  <canvas class="particle-canvas" data-particle-canvas aria-hidden="true"
  ></canvas>

  <main
    class="relative z-10 min-h-[100vh] flex flex-col items-center justify-center text-center px-5 pointer-events-none">
    <div
      data-reveal
      class="hero-eyebrow inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 backdrop-blur-sm px-3 py-1.5 text-[11px] tracking-[0.22em] uppercase text-bone/80 pointer-events-auto">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-white/85 hero-dot"
      ></span>
       Independent studio &middot; est. 2001
    </div>

    <!-- Spacer that reserves room for the particle wordmark.
         The actual word is painted by the canvas; this just keeps layout. -->
    <div
      class="particle-spacer"
      aria-label="4DPrime"
      role="heading"
      aria-level="1">
      <h1 class="sr-only">4DPrime &mdash; Rocket your ideas.</h1>
    </div>

    <p
      data-reveal
      data-reveal-delay="280"
      class="hero-sub mt-6 max-w-xl text-base sm:text-lg lg:text-xl text-bone/70 leading-relaxed [text-wrap:balance] pointer-events-auto">
      25+ years turning ideas into stunning mobile apps, websites, bespoke
      software and AI.
    </p>

    <div
      data-reveal
      data-reveal-delay="440"
      class="hero-actions mt-9 flex flex-col sm:flex-row gap-3 items-center pointer-events-auto">
      <a href="/contact" class="btn-primary btn-magnetic group">
        <span>Start a conversation</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          class="w-4 h-4 transition-transform group-hover:translate-x-1">
          <path
            fill-rule="evenodd"
            d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
            clip-rule="evenodd"></path>
        </svg>
      </a>
      <a href="#what-we-make" class="btn-ghost-dark group">
        <span>See what we make</span>
      </a>
    </div>

    <p
      data-reveal
      data-reveal-delay="600"
      class="hero-hint mt-8 text-[11px] uppercase tracking-[0.25em] text-bone/35">
      &mdash; move your cursor &mdash;
    </p>
  </main>

  <a
    href="#what-we-make"
    aria-label="Scroll to what we make"
    class="scroll-cue absolute left-1/2 -translate-x-1/2 bottom-8 z-10 hidden sm:flex flex-col items-center gap-2 text-bone/45 hover:text-bone transition-colors">
    <span class="text-[10px] uppercase tracking-[0.3em]">Scroll</span>
    <span class="scroll-cue-track"><span class="scroll-cue-dot"></span></span>
  </a>

  <!-- Sunrise horizon: standing on a WHITE planet, watching a WHITE sun rise
       over the curve. White light bleeds upward into the dark cosmic hero.
       Scroll drives --rise. -->
  <div class="hero-horizon" data-hero-horizon aria-hidden="true">
    <div class="horizon-glow"></div>
    <div class="horizon-planet"></div>
  </div>
</section>

<style>
  .particle-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  /* Reserve vertical space where the particle wordmark sits */
  .particle-spacer {
    width: 100%;
    height: clamp(160px, 30vh, 360px);
    margin-top: 2.5rem;
  }

  .hero-dot {
    box-shadow: 0 0 8px 2px rgba(255, 255, 255, 0.55);
    animation: dotPulse 3.6s ease-in-out infinite;
  }
  @keyframes dotPulse {
    0%,
    100% {
      opacity: 0.65;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.25);
    }
  }

  .scroll-cue-track {
    display: block;
    width: 1.5px;
    height: 36px;
    background: rgba(255, 255, 255, 0.18);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }
  .scroll-cue-dot {
    position: absolute;
    left: 50%;
    top: -6px;
    transform: translateX(-50%);
    width: 1.5px;
    height: 12px;
    background: linear-gradient(180deg, transparent, #ffffff);
    animation: scrollCueGlide 2.4s cubic-bezier(0.55, 0, 0.45, 1) infinite;
  }
  @keyframes scrollCueGlide {
    0% {
      top: -12px;
      opacity: 0;
    }
    15% {
      opacity: 1;
    }
    75% {
      opacity: 1;
    }
    100% {
      top: 36px;
      opacity: 0;
    }
  }

  .hero-hint {
    opacity: 0;
    animation:
      hintFade 1.4s ease-out 1.2s forwards,
      hintBreathe 4s ease-in-out 2.6s infinite;
  }
  @keyframes hintFade {
    0% {
      opacity: 0;
      transform: translateY(6px);
    }
    100% {
      opacity: 0.5;
      transform: translateY(0);
    }
  }
  @keyframes hintBreathe {
    0%,
    100% {
      opacity: 0.35;
    }
    50% {
      opacity: 0.6;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-dot,
    .scroll-cue-dot,
    .hero-hint {
      animation: none;
    }
  }

  /* ============================================================
     SUNRISE HORIZON — standing on a WHITE planet.
     A huge white disc forms the gently-curved horizon across the full
     page width. A white sun rises from behind it, its halo bleeding
     upward into the dark cosmic sky. --rise (0..1) is set from JS
     based on scroll progress.
     ============================================================ */
  .hero-horizon {
    --rise: 0;
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 55vh;
    min-height: 340px;
    max-height: 620px;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
    will-change: contents;
  }

  /* A very subtle atmospheric haze that builds with --rise. It's the wider
     wash of light that sits beyond the sun's main glow — what you see
     when the entire sky brightens just before dawn. */
  .horizon-glow {
    position: absolute;
    /* Stay within the horizon container — no extension up into the hero. */
    inset: 0;
    background: radial-gradient(
      ellipse 170% 55% at 50% calc(118% - var(--rise) * 30%),
      rgba(255, 255, 255, 0.78) 0%,
      rgba(245, 250, 255, 0.5) 16%,
      rgba(220, 232, 255, 0.25) 42%,
      rgba(200, 218, 255, 0.08) 68%,
      transparent 88%
    );
    mix-blend-mode: screen;
    /* Invisible at rest — appears only as you scroll, ramping fast. */
    opacity: min(1, calc(var(--rise) * 2.6));
    transition: opacity 80ms linear;
  }

  /* Sun layer removed — composition is just the planet curve + atmosphere. */

  /* The white planet's surface — a huge white disc whose top arc spans the
     full page width with a gentle planetary curve (high in the middle,
     dipping toward the edges). Below the arc is solid white that blends
     into the white content section beneath the hero. */
  .horizon-planet {
    --planet-d: 800vw;
    position: absolute;
    left: 50%;
    top: calc(100% - 70px);
    width: var(--planet-d);
    height: var(--planet-d);
    margin-left: calc(var(--planet-d) / -2);
    border-radius: 50%;
    background: #ffffff;
    /* A subtle atmospheric rim of cool light just above the horizon. */
    box-shadow:
      0 -1px 0 rgba(255, 255, 255, 0.95),
      0 -10px 30px rgba(255, 255, 255, 0.35),
      0 -40px 90px rgba(210, 226, 255, 0.18);
  }

  @media (max-width: 640px) {
    .hero-horizon {
      height: 42vh;
      min-height: 260px;
    }
    .horizon-planet {
      --planet-d: 1100vw;
      top: calc(100% - 50px);
    }
  }
</style>

<script>
  // ============================================================
  // PARTICLE WORDMARK — interactive, cursor-disrupted typography
  // ============================================================
  function initParticleHero() {
    const canvas = document.querySelector<HTMLCanvasElement>(
      '[data-particle-canvas]',
    )
    if (!canvas) return
    const ctx = canvas.getContext('2d', { alpha: true })
    if (!ctx) return

    const reduced = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches

    const WORD = 'Rocket your ideas'

    interface Particle {
      hx: number
      hy: number // home position
      x: number
      y: number // current
      vx: number
      vy: number // velocity
      r: number // radius
      h: number // hue offset 0..1 across word (for color)
      cj: number // per-particle colour jitter (-0.06..+0.06), stable
      tw: number // twinkle phase
    }
    let particles: Particle[] = []

    let dpr = Math.min(window.devicePixelRatio || 1, 1.6)
    let w = 0,
      h = 0
    let mx = -9999,
      my = -9999 // mouse (offscreen by default)
    let lastMove = 0
    let raf = 0

    function resize() {
      const rect = canvas.getBoundingClientRect()
      w = Math.max(1, Math.floor(rect.width * dpr))
      h = Math.max(1, Math.floor(rect.height * dpr))
      if (canvas.width !== w || canvas.height !== h) {
        canvas.width = w
        canvas.height = h
      }
      buildParticles()
    }

    function wrapByWords(
      text: string,
      maxWidth: number,
      m: CanvasRenderingContext2D,
    ): string[] {
      const words = text.split(' ')
      const lines: string[] = []
      let line = ''
      for (const word of words) {
        const candidate = line ? line + ' ' + word : word
        if (m.measureText(candidate).width <= maxWidth || !line) {
          line = candidate
        } else {
          lines.push(line)
          line = word
        }
      }
      if (line) lines.push(line)
      return lines
    }

    function buildParticles() {
      const cssW = w / dpr
      const cssH = h / dpr
      const isSmall = cssW < 700
      const isTiny = cssW < 480

      // Available width for the wordmark (CSS pixels)
      const fitWidth = cssW * (isTiny ? 0.94 : isSmall ? 0.92 : 0.72)

      // Measurement context for picking font size
      const off = document.createElement('canvas')
      const octx = off.getContext('2d')!

      // 1) Try the whole phrase on one line and see what font size that needs.
      octx.font = `800 100px 'Inter Variable', Inter, system-ui, sans-serif`
      const fullAt100 = Math.max(1, octx.measureText(WORD).width)
      const longestWord = WORD.split(' ').reduce(
        (a, b) => (a.length >= b.length ? a : b),
        '',
      )
      const longestAt100 = Math.max(1, octx.measureText(longestWord).width)

      // What font size would the whole phrase need to fill our fitWidth?
      const oneLineFont = (fitWidth / fullAt100) * 100

      // Ideal "hero size" font, capped by available height
      const idealFont = Math.min(
        isTiny ? cssW * 0.2 : isSmall ? cssW * 0.16 : cssW * 0.11,
        cssH * 0.22,
      )

      let fontPx: number
      let lines: string[]

      if (oneLineFont >= idealFont * 0.75 && !isTiny) {
        // The phrase fits well enough on one line at a respectable size
        fontPx = Math.min(oneLineFont, idealFont)
        lines = [WORD]
      } else {
        // Wrap into multiple lines, sized so the longest word still fills nicely
        fontPx = Math.min((fitWidth / longestAt100) * 100, idealFont)
        octx.font = `800 ${fontPx}px 'Inter Variable', Inter, system-ui, sans-serif`
        lines = wrapByWords(WORD, fitWidth, octx)
      }

      // Cap by total height — never let the wordmark exceed ~58% of the canvas
      const lineH = fontPx * 1.02
      const maxTotalH = cssH * 0.58
      if (lines.length * lineH > maxTotalH) {
        fontPx = maxTotalH / lines.length / 1.02
        octx.font = `800 ${fontPx}px 'Inter Variable', Inter, system-ui, sans-serif`
        lines = wrapByWords(WORD, fitWidth, octx)
      }

      fontPx = Math.max(28, fontPx)

      // Resize offscreen canvas to fit all lines
      const finalLineH = fontPx * 1.02
      const padH = fontPx * 0.3
      const totalH = lines.length * finalLineH + padH * 2
      const ow = Math.floor(w)
      const oh = Math.max(2, Math.floor(totalH * dpr))
      off.width = ow
      off.height = oh

      // Setup must happen AFTER resizing (resize clears state)
      const octx2 = off.getContext('2d')!
      octx2.scale(dpr, dpr)
      octx2.fillStyle = '#fff'
      octx2.font = `800 ${fontPx}px 'Inter Variable', Inter, system-ui, sans-serif`
      octx2.textAlign = 'center'
      octx2.textBaseline = 'middle'

      // Draw each line, vertically stacked & centered
      const startY = padH + finalLineH / 2
      for (let i = 0; i < lines.length; i++) {
        octx2.fillText(lines[i], cssW / 2, startY + i * finalLineH)
      }

      const img = octx2.getImageData(0, 0, ow, oh)

      // Density: keep particle count manageable on tiny screens
      const step = isTiny ? 6 : isSmall ? 5 : 4

      // Resize the layout spacer to fit the wordmark — this prevents
      // the wrapped multi-line text from colliding with the subtitle below.
      const spacer = document.querySelector<HTMLElement>('.particle-spacer')
      if (spacer) spacer.style.height = totalH + 'px'

      // Anchor the wordmark inside the spacer (force layout read after the
      // height change so getBoundingClientRect reflects the new size).
      const sRect = spacer ? spacer.getBoundingClientRect() : null
      const cRect = canvas.getBoundingClientRect()
      const targetCenterY =
        sRect && sRect.height > 0
          ? (sRect.top + sRect.bottom) / 2 - cRect.top
          : cssH * 0.45
      const offsetY = (targetCenterY - totalH / 2) * dpr

      const newPositions: { x: number; y: number; hRatio: number }[] = []
      for (let y = 0; y < img.height; y += step) {
        for (let x = 0; x < img.width; x += step) {
          const i = (y * img.width + x) * 4
          if (img.data[i + 3] > 130) {
            newPositions.push({
              x,
              y: y + offsetY,
              hRatio: x / img.width,
            })
          }
        }
      }

      // Reuse particles where possible to avoid full re-init
      const next: Particle[] = []
      for (let i = 0; i < newPositions.length; i++) {
        const np = newPositions[i]
        const existing = particles[i]
        if (existing) {
          existing.hx = np.x
          existing.hy = np.y
          existing.h = np.hRatio
          // Backfill cj if missing from previous build
          if (typeof existing.cj !== 'number') {
            existing.cj = (Math.random() - 0.5) * 0.13
          }
          next.push(existing)
        } else {
          // Spawn from random off-screen positions for the initial gather effect
          next.push({
            hx: np.x,
            hy: np.y,
            x: Math.random() * w,
            y: Math.random() * h,
            vx: (Math.random() - 0.5) * 4,
            vy: (Math.random() - 0.5) * 4,
            r: (Math.random() * 0.8 + 0.7) * dpr,
            h: np.hRatio,
            cj: (Math.random() - 0.5) * 0.13, // ±0.065 stable jitter
            tw: Math.random() * Math.PI * 2,
          })
        }
      }
      particles = next
    }

    // Brand colour palette — sampled across the wordmark.
    // Stops are interpolated in RGB so the gradient feels continuous.
    const PALETTE: Array<[number, number, number]> = [
      [99, 102, 241], // iris
      [139, 92, 246], // violet
      [34, 211, 238], // cyan
      [244, 114, 182], // plasma
      [251, 191, 36], // solar
    ]
    function sampleColor(t: number): [number, number, number] {
      // wrap t into 0..1 (allows drift to go past edges)
      let u = t - Math.floor(t)
      const seg = u * (PALETTE.length - 1)
      const i = Math.floor(seg)
      let f = seg - i
      // Smoothstep the segment fraction so transitions between stops are
      // S-curved instead of hard linear — kills sharp visual band edges.
      f = f * f * (3 - 2 * f)
      const a = PALETTE[i]
      const b = PALETTE[Math.min(i + 1, PALETTE.length - 1)]
      return [
        a[0] + (b[0] - a[0]) * f,
        a[1] + (b[1] - a[1]) * f,
        a[2] + (b[2] - a[2]) * f,
      ]
    }

    function tick(now: number) {
      // Subtle trail effect for motion blur look
      ctx.fillStyle = 'rgba(6, 6, 15, 0.22)'
      ctx.fillRect(0, 0, w, h)

      // 'screen' instead of 'lighter' so overlapping particles in dense
      // letter regions preserve their colour instead of bleaching to white.
      ctx.globalCompositeOperation = 'screen'

      const mxC = mx * dpr
      const myC = my * dpr
      const disturbR = 140 * dpr
      const disturbR2 = disturbR * disturbR

      // Slow idle breath: a soft wave that travels left→right across the word
      const breath = Math.sin(now * 0.001) * 0.5 + 0.5
      // Slow palette drift — entire word's gradient slides through the palette
      const paletteDrift = (now * 0.00006) % 1

      for (let i = 0; i < particles.length; i++) {
        const p = particles[i]

        // Spring back to home
        const dxh = p.hx - p.x
        const dyh = p.hy - p.y
        p.vx += dxh * 0.018
        p.vy += dyh * 0.018

        // Damping
        p.vx *= 0.86
        p.vy *= 0.86

        // Cursor repulsion
        if (mxC > -1000) {
          const mdx = p.x - mxC
          const mdy = p.y - myC
          const d2 = mdx * mdx + mdy * mdy
          if (d2 < disturbR2 && d2 > 0.01) {
            const d = Math.sqrt(d2)
            const force = ((disturbR - d) / disturbR) * 4.5
            p.vx += (mdx / d) * force
            p.vy += (mdy / d) * force
          }
        }

        // Tiny ambient noise so the word never looks static
        p.vx += (Math.random() - 0.5) * 0.05
        p.vy += (Math.random() - 0.5) * 0.05

        p.x += p.vx
        p.y += p.vy

        // === COLOUR ===
        // Position across the word + drift gives the band travelling effect.
        // Disturbed particles flash further along the palette toward plasma.
        const dispMag = Math.hypot(dxh, dyh)
        const tight = Math.max(0, 1 - dispMag / 200)
        const disturbBoost = Math.min(0.35, dispMag / 240)
        // Per-particle jitter dithers band edges; cj is stable per particle
        // so the colour doesn't shimmer frame-to-frame.
        const t = p.h * 0.7 + paletteDrift + disturbBoost + p.cj

        const [cr, cg, cb] = sampleColor(t)

        // Each particle keeps near-full palette saturation; with 'screen'
        // blending, overlap builds richness without bleaching to white.
        const energy = 0.85 + tight * 0.12 + breath * 0.06 + disturbBoost * 0.2
        const r = Math.min(255, cr * energy)
        const g = Math.min(255, cg * energy)
        const b = Math.min(255, cb * energy)

        const alpha = 0.6 + tight * 0.25 + disturbBoost * 0.1

        ctx.fillStyle = `rgba(${r | 0}, ${g | 0}, ${b | 0}, ${alpha})`
        ctx.beginPath()
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2)
        ctx.fill()
      }

      ctx.globalCompositeOperation = 'source-over'

      raf = requestAnimationFrame(tick)
    }

    function onMove(e: PointerEvent) {
      const rect = canvas.getBoundingClientRect()
      mx = e.clientX - rect.left
      my = e.clientY - rect.top
      lastMove = performance.now()
    }
    function onLeave() {
      mx = -9999
      my = -9999
    }
    window.addEventListener('pointermove', onMove, { passive: true })
    window.addEventListener('pointerleave', onLeave)

    // Resize observer
    const ro = new ResizeObserver(resize)
    ro.observe(canvas)
    resize()

    if (!reduced) raf = requestAnimationFrame(tick)
  }

  initParticleHero()
  document.addEventListener('astro:after-swap', initParticleHero)

  // ============================================================
  // SUNRISE HORIZON — scroll-linked --rise on the horizon container
  // ============================================================
  function initSunrise() {
    const hero = document.querySelector<HTMLElement>('.hero')
    const horizon = document.querySelector<HTMLElement>('[data-hero-horizon]')
    if (!hero || !horizon) return

    let cur = 0
    let target = 0
    let raf = 0

    function compute() {
      const rect = hero.getBoundingClientRect()
      const heroH = Math.max(1, rect.height)
      // How much of the hero has scrolled past the top of the viewport.
      const scrolled = Math.max(0, -rect.top)
      // Map: sun starts rising at 5% scroll, fully risen by 75% of hero height.
      const start = heroH * 0.05
      const end = heroH * 0.75
      const t = Math.max(
        0,
        Math.min(1, (scrolled - start) / Math.max(1, end - start)),
      )
      // Ease-out for a softer settle near peak.
      target = 1 - Math.pow(1 - t, 2)
    }

    function tick() {
      // Smooth toward target so quick scroll wheels still look cinematic.
      cur += (target - cur) * 0.18
      horizon.style.setProperty('--rise', cur.toFixed(3))
      if (Math.abs(target - cur) > 0.001) {
        raf = requestAnimationFrame(tick)
      } else {
        cur = target
        horizon.style.setProperty('--rise', cur.toFixed(3))
        raf = 0
      }
    }

    function onScroll() {
      compute()
      if (!raf) raf = requestAnimationFrame(tick)
    }

    window.addEventListener('scroll', onScroll, { passive: true })
    window.addEventListener('resize', onScroll)
    compute()
    cur = target
    horizon.style.setProperty('--rise', cur.toFixed(3))
  }

  initSunrise()
  document.addEventListener('astro:after-swap', initSunrise)
</script>
