---
import Container from '@components/container.astro'

const { margin } = Astro.props

const footermenu = {
  company: [
    { title: 'About', path: '/about/' },
    { title: 'Blog', path: '/blog/' },
    { title: 'Contact', path: '/contact/' },
  ],
  product: [
    { title: 'Mobile Apps', path: '/mobile-apps/' },
    { title: 'Websites', path: '/websites/' },
    { title: 'Artificial Intelligence', path: '/ai/' },
    { title: 'Bespoke Software', path: '/development/' },
  ],
  resources: [
    { title: 'Portfolio', path: '/portfolio/' },
    { title: 'Client Testimonials', path: '/testimonials/' },
    { title: 'Privacy Policy', path: '/privacy/' },
    { title: 'Terms & Conditions', path: '/terms/' },
  ],
}
---

<footer
  class:list={[
    'relative bg-ink text-bone overflow-hidden grain',
    margin && 'mt-10',
  ]}>
  <!-- gradient hairline top -->
  <div
    class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-violet/60 to-transparent">
  </div>

  <!-- soft background glows -->
  <div
    class="pointer-events-none absolute -top-32 -left-32 w-96 h-96 rounded-full bg-iris/20 blur-3xl">
  </div>
  <div
    class="pointer-events-none absolute -bottom-32 -right-32 w-96 h-96 rounded-full bg-cyan/15 blur-3xl">
  </div>

  <Container class="relative z-10 py-16">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8">
      <div class="sm:col-span-2 md:col-span-3 lg:col-span-2">
        <a
          href="/"
          class="text-lg flex items-center transition focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-iris focus-visible:outline-none rounded-full px-2 -ml-2">
          <img src="/4dprime-dark.png" width="450" height="119" alt="4DPrime" class="logo" />
        </a>
        <div class="mt-6 text-sm space-y-3">
          <div
            class="flex items-center gap-2 text-bone/70 hover:text-bone transition">
            <svg
              viewBox="0 0 24 24"
              class="w-4 h-4 text-cyan"
              fill="currentColor"
              ><path
                d="M19 4H5a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h14a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3zm-.41 2-5.88 5.88a1 1 0 0 1-1.42 0L5.41 6zM20 17a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7.41l5.88 5.88a3 3 0 0 0 4.24 0L20 7.41z"
              ></path></svg
            >
            <a href="mailto:info@4dprime.com">info@4dprime.com</a>
          </div>
          <div
            class="flex items-center gap-2 text-bone/70 hover:text-bone transition">
            <svg
              viewBox="0 0 24 24"
              class="w-4 h-4 text-cyan"
              fill="currentColor"
              ><path
                d="M19.44 13c-.22 0-.45-.07-.67-.12a9.44 9.44 0 0 1-1.31-.39 2 2 0 0 0-2.48 1l-.22.45a12.18 12.18 0 0 1-2.66-2 12.18 12.18 0 0 1-2-2.66l.42-.28a2 2 0 0 0 1-2.48 10.33 10.33 0 0 1-.39-1.31c-.05-.22-.09-.45-.12-.68a3 3 0 0 0-3-2.49h-3a3 3 0 0 0-3 3.41 19 19 0 0 0 16.52 16.46h.38a3 3 0 0 0 2-.76 3 3 0 0 0 1-2.25v-3a3 3 0 0 0-2.47-2.9z"
              ></path></svg
            >
            <a href="tel:+441376350001">+44 (0) 1376 350001</a>
          </div>
          <div class="pt-4 text-xs text-bone/40 space-y-1">
            <p>4DPrime is a trading name of Soft Idiom Limited</p>
            <p>VAT Registration No.: 786609380</p>
            <p>Registered in England No. 04283151</p>
          </div>
        </div>
      </div>

      <div>
        <h3 class="font-medium text-sm text-bone uppercase tracking-[0.15em]">
          Company
        </h3>
        <div class="flex flex-col mt-4">
          {
            footermenu.company.map((item) => (
              <a
                href={item.path || '#'}
                class="py-1.5 text-sm text-bone/60 hover:text-cyan transition">
                {item.title}
              </a>
            ))
          }
        </div>
      </div>
      <div>
        <h3 class="font-medium text-sm text-bone uppercase tracking-[0.15em]">
          Product
        </h3>
        <div class="flex flex-col mt-4">
          {
            footermenu.product.map((item) => (
              <a
                href={item.path || '#'}
                class="py-1.5 text-sm text-bone/60 hover:text-cyan transition">
                {item.title}
              </a>
            ))
          }
        </div>
      </div>
      <div>
        <h3 class="font-medium text-sm text-bone uppercase tracking-[0.15em]">
          Resources
        </h3>
        <div class="flex flex-col mt-4">
          {
            footermenu.resources.map((item) => (
              <a
                href={item.path || '#'}
                class="py-1.5 text-sm text-bone/60 hover:text-cyan transition">
                {item.title}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </Container>

  <div class="relative z-10 border-t border-white/10">
    <Container
      class="py-6 flex flex-col md:flex-row items-center justify-between gap-2">
      <p class="text-xs text-bone/40">
        Copyright © 2001–{new Date().getFullYear()} 4DPrime. All rights
        reserved.
      </p>
      <p class="text-xs text-bone/40 inline-flex items-center gap-2">
        <span
          class="inline-block w-1.5 h-1.5 rounded-full bg-cyan animate-pulse shadow-[0_0_8px_2px_rgba(34,211,238,0.7)]"
        ></span>
         Crafted in the United Kingdom
      </p>
    </Container>
  </div>
</footer>

<style>
  .logo {
    width: 150px;
    height: auto;
  }
</style>
