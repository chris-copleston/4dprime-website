---
const { align = 'center' } = Astro.props
---

<div class:list={['mt-12 lg:mt-16', align === 'center' && 'text-center']} data-reveal>
  {
    Astro.slots.has('badge') && (
      <p class="text-xs uppercase tracking-[0.25em] text-violet mb-3">
        <slot name="badge" />
      </p>
    )
  }
  <h1 class="text-4xl lg:text-6xl font-bold tracking-[-0.03em] [text-wrap:balance]">
    <slot name="title">Title</slot>
  </h1>
  <p class:list={['text-lg mt-5 text-slate-600 max-w-2xl [text-wrap:pretty]', align === 'center' && 'mx-auto']}>
    <slot name="desc">Some description goes here</slot>
  </p>
</div>
