---
interface Props {
  href: string;
  size?: "md" | "lg" | "sm";
  block?: boolean;
  style?: "outline" | "primary" | "inverted" | "muted";
  class?: string;
  [x: string]: any;
}

const {
  href,
  block,
  size = "lg",
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  lg: "px-7 py-3 text-base",
  md: "px-5 py-2.5 text-sm",
  sm: "px-4 py-2 text-sm",
};

const styles = {
  outline: "bg-transparent border border-slate-300 text-slate-900 hover:bg-slate-50",
  primary: "bg-slate-900 text-white hover:bg-slate-800",
  inverted: "bg-white text-slate-900 hover:bg-slate-100",
  muted: "bg-slate-100 hover:bg-slate-200 text-slate-900",
};
---

<a
  href={href}
  {...rest}
  class:list={[
    "inline-flex items-center justify-center rounded-full font-medium tracking-tight transition focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-slate-900 focus-visible:outline-none",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}>
  <slot />
</a>
