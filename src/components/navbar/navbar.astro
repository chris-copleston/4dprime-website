---
import Container from '@components/container.astro'
import Dropdown from './dropdown.astro'
import { StickyHeader, Astronav, MenuItems, MenuIcon } from 'astro-navbar'

const menuitems = [
  { title: 'Mobile Apps', path: '/mobile-apps' },
  { title: 'Websites', path: '/websites' },
  { title: 'Development', path: '/development' },
  { title: 'AI', path: '/ai' },
  {
    title: 'About',
    path: '#',
    children: [
      { title: 'About Us', path: '/about' },
      { title: 'Portfolio', path: '/portfolio' },
      { title: 'Testimonials', path: '/testimonials' },
      { title: 'Our Blog', path: '/blog' },
      { title: 'Contact Us', path: '/contact' },
    ],
  },
]
---

<StickyHeader
  class="navbar sticky top-0 z-30 transition-all"
  scrollY={50}
  defaultClass="py-4 border-transparent"
  activeClass="py-3 navbar-active">
  <Container>
    <div
      class="flex flex-col lg:flex-row justify-between items-center relative z-10"
      transition:animate="none">
      <Astronav>
        <div class="flex w-full lg:w-auto items-center justify-between">
          <a
            href="/"
            class="flex items-center transition focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-iris focus-visible:outline-none rounded-full px-2 -ml-2">
            <img src="/logo.svg" alt="4DPrime" class="logo" />
          </a>
          <div class="block lg:hidden">
            <MenuIcon class="w-8 h-8 text-gray-800" />
          </div>
        </div>
        <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
          <ul class="flex flex-col lg:flex-row lg:gap-1 lg:items-center">
            <li class="hidden lg:block px-1">
              <a href="/" aria-label="Home page" class="nav-icon-btn">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" class="w-4 h-4 fill-current">
                  <path d="M298.6 4c-6-5.3-15.1-5.3-21.2 0L5.4 244c-6.6 5.8-7.3 16-1.4 22.6s16 7.3 22.6 1.4L64 235l0 197c0 44.2 35.8 80 80 80l288 0c44.2 0 80-35.8 80-80l0-197 37.4 33c6.6 5.8 16.7 5.2 22.6-1.4s5.2-16.7-1.4-22.6L298.6 4zM96 432l0-225.3L288 37.3 480 206.7 480 432c0 26.5-21.5 48-48 48l-64 0 0-160c0-17.7-14.3-32-32-32l-96 0c-17.7 0-32 14.3-32 32l0 160-64 0c-26.5 0-48-21.5-48-48zm144 48l0-160 96 0 0 160-96 0z"/>
                </svg>
              </a>
            </li>
            {menuitems.map((item, index) => (
              <li class="font-medium">
                {item.children && (
                  <Dropdown
                    title={item.title}
                    children={item.children}
                    lastItem={index === menuitems.length - 1}
                  />
                )}
                {!item.children && (
                  <a
                    href={item.path}
                    class="nav-link flex justify-center lg:px-3 py-2 text-lg lg:text-sm">
                    {item.title}
                  </a>
                )}
              </li>
            ))}
          </ul>
          <div class="lg:hidden flex items-center mt-3 gap-4">
            <a href="/search" class="nav-link text-sm">Search</a>
            <a href="/contact" class="cta-pill">Let's chat</a>
          </div>
        </MenuItems>
      </Astronav>
      <div>
        <div class="hidden lg:flex items-center gap-3">
          <a href="/search" aria-label="Website search" class="nav-icon-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
              <circle cx="11" cy="11" r="7"/>
              <path d="m21 21-4.3-4.3"/>
            </svg>
          </a>
          <a
            href="/contact"
            class="cta-pill btn-magnetic group">
            <span class="relative z-10 flex items-center gap-1.5">
              Let's chat
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5">
                <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </Container>
</StickyHeader>

<style is:global>
  .navbar {
    backdrop-filter: blur(0px);
  }
  .navbar-active {
    background: rgba(255, 255, 255, 0.75);
    border-bottom: 1px solid transparent;
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    position: relative;
  }
  .navbar-active::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.45), rgba(34, 211, 238, 0.45), transparent);
  }
  .logo { width: 150px; height: 36.48px; }
  .nav-link {
    position: relative;
    color: rgb(75, 85, 99);
    border-radius: 9999px;
    transition: color 0.2s;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 50%; bottom: 4px;
    width: 0; height: 1px;
    background: linear-gradient(90deg, #6366F1, #22D3EE);
    transition: width 0.25s cubic-bezier(0.16, 1, 0.3, 1), left 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-link:hover { color: #4338CA; }
  .nav-link:hover::after { width: calc(100% - 1.5rem); left: 0.75rem; }
  .nav-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    border-radius: 9999px;
    color: rgb(75, 85, 99);
    transition: background 0.2s, color 0.2s;
  }
  .nav-icon-btn:hover { background: rgba(99, 102, 241, 0.08); color: #4338CA; }
  .cta-pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 1.1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #ffffff;
    border-radius: 9999px;
    background: #0A0B1F;
    transition: background 0.2s, transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cta-pill:hover { background: #1f2233; }
</style>
